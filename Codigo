import type { TopicId } from '../content/topics'

const STORAGE_KEY = 'aprende-jugando:progress:v1'

export type BestQuizScore = { score: number; total: number }

export type ProgressState = {
  completedLessonIds: string[]
  bestQuizScoreByTopic: Partial<Record<TopicId, BestQuizScore>>
}

const DEFAULT_STATE: ProgressState = {
  completedLessonIds: [],
  bestQuizScoreByTopic: {},
}

export function loadProgress(): ProgressState {
  try {
    const raw = localStorage.getItem(STORAGE_KEY)
    if (!raw) return DEFAULT_STATE
    const parsed = JSON.parse(raw) as unknown
    if (!parsed || typeof parsed !== 'object') return DEFAULT_STATE

    const obj = parsed as Partial<ProgressState>
    const completedLessonIds = Array.isArray(obj.completedLessonIds)
      ? obj.completedLessonIds.filter((x): x is string => typeof x === 'string')
      : []
    const bestQuizScoreByTopic =
      obj.bestQuizScoreByTopic && typeof obj.bestQuizScoreByTopic === 'object'
        ? (obj.bestQuizScoreByTopic as ProgressState['bestQuizScoreByTopic'])
        : {}

    return { completedLessonIds, bestQuizScoreByTopic }
  } catch {
    return DEFAULT_STATE
  }
}

export function saveProgress(state: ProgressState) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state))
}




