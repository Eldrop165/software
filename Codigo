import { useMemo, useState } from 'react'
import type { QuizQuestion, Topic } from '../content/topics'
import type { ProgressState } from '../lib/progress'

type AnswerState = Record<string, number>

function scoreQuiz(questions: QuizQuestion[], answers: AnswerState) {
  return questions.reduce((acc, q) => {
    const a = answers[q.id]
    return acc + (a === q.answerIndex ? 1 : 0)
  }, 0)
}

export function QuizScreen(props: {
  topic: Topic
  progress: ProgressState
  onBack: () => void
  onFinish: (score: number, total: number) => void
}) {
  const questions = props.topic.quiz
  const [answers, setAnswers] = useState<AnswerState>({})
  const [submitted, setSubmitted] = useState(false)

  const score = useMemo(() => scoreQuiz(questions, answers), [answers, questions])
  const total = questions.length
  const doneCount = Object.keys(answers).length

  const best = props.progress.bestQuizScoreByTopic[props.topic.id]
  const bestText = best ? `${best.score}/${best.total}` : '—'

  return (
    <section className="screen">
      <div className="card">
        <div className="row">
          <button className="ghostBtn" onClick={props.onBack}>
            ← {props.topic.title}
          </button>
          <span className="pill">Mejor: {bestText}</span>
        </div>

        <div className="topicHeader">
          <div className="topicEmojiBig" aria-hidden="true">
            {props.topic.emoji}
          </div>
          <div>
            <h1 className="h1">Quiz de {props.topic.title}</h1>
            <p className="lead">Responde y luego toca “Terminar”.</p>
          </div>
        </div>

        <div className="quizMeta">
          <span className="pill">
            Respondidas: {doneCount}/{total}
          </span>
          {submitted ? (
            <span className={score / total >= 0.8 ? 'pillOk' : 'pill'}>
              Puntos: {score}/{total}
            </span>
          ) : (
            <span className="pill">Puntos: —</span>
          )}
        </div>

        <div className="quizList">
          {questions.map((q, idx) => {
            const selected = answers[q.id]
            const show = submitted
            return (
              <div key={q.id} className="quizQ">
                <div className="quizPrompt">
                  <span className="badge">{idx + 1}</span> {q.prompt}
                </div>
                <div className="quizOptions">
                  {q.options.map((opt, oi) => {
                    const isSelected = selected === oi
                    const isRight = show && oi === q.answerIndex
                    const isWrongSelected = show && isSelected && oi !== q.answerIndex
                    const className = isRight
                      ? 'opt optRight'
                      : isWrongSelected
                        ? 'opt optWrong'
                        : isSelected
                          ? 'opt optSelected'
                          : 'opt'
                    return (
                      <button
                        key={oi}
                        className={className}
                        onClick={() => {
                          if (submitted) return
                          setAnswers((prev) => ({ ...prev, [q.id]: oi }))
                        }}
                        aria-pressed={isSelected}
                      >
                        {opt}
                      </button>
                    )
                  })}
                </div>
                {submitted && q.helper ? <div className="hint">{q.helper}</div> : null}
              </div>
            )
          })}
        </div>

        <div className="row" style={{ marginTop: 12 }}>
          <button
            className="secondaryBtn"
            onClick={() => {
              setAnswers({})
              setSubmitted(false)
            }}
          >
            Reiniciar quiz
          </button>
          <button
            className="primaryBtn"
            onClick={() => {
              setSubmitted(true)
              props.onFinish(score, total)
            }}
            disabled={doneCount !== total}
          >
            Terminar
          </button>
        </div>
      </div>
    </section>
  )
}





