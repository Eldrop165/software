import { useMemo, useState } from 'react'
import { TOPICS, type TopicId } from './content/topics'
import { loadProgress, saveProgress, type ProgressState } from './lib/progress'
import { HomeScreen } from './screens/HomeScreen'
import { LessonScreen } from './screens/LessonScreen'
import { QuizScreen } from './screens/QuizScreen'
import { TopicScreen } from './screens/TopicScreen'

type Route =
  | { name: 'home' }
  | { name: 'topic'; topicId: TopicId }
  | { name: 'lesson'; topicId: TopicId; lessonId: string }
  | { name: 'quiz'; topicId: TopicId }

export default function App() {
  const [route, setRoute] = useState<Route>({ name: 'home' })
  const [progress, setProgress] = useState<ProgressState>(() => loadProgress())

  const topicsById = useMemo(() => {
    return new Map(TOPICS.map((t) => [t.id, t]))
  }, [])

  function updateProgress(next: ProgressState) {
    setProgress(next)
    saveProgress(next)
  }

  return (
    <div className="appShell">
      <header className="topBar">
        <button
          className="ghostBtn"
          onClick={() => setRoute({ name: 'home' })}
          aria-label="Volver al inicio"
        >
          Aprende Jugando
        </button>
        <div className="topBarRight">
          <span className="pill" title="Progreso guardado en el dispositivo">
            Progreso: {progress.completedLessonIds.length} lecciones
          </span>
        </div>
      </header>

      <main className="content">
        {route.name === 'home' && (
          <HomeScreen
            topics={TOPICS}
            progress={progress}
            onOpenTopic={(topicId) => setRoute({ name: 'topic', topicId })}
            onReset={() =>
              updateProgress({ completedLessonIds: [], bestQuizScoreByTopic: {} })
            }
          />
        )}

        {route.name === 'topic' && (
          <TopicScreen
            topic={topicsById.get(route.topicId)!}
            progress={progress}
            onBack={() => setRoute({ name: 'home' })}
            onOpenLesson={(lessonId) =>
              setRoute({ name: 'lesson', topicId: route.topicId, lessonId })
            }
            onStartQuiz={() => setRoute({ name: 'quiz', topicId: route.topicId })}
          />
        )}

        {route.name === 'lesson' && (
          <LessonScreen
            topic={topicsById.get(route.topicId)!}
            lessonId={route.lessonId}
            progress={progress}
            onBack={() => setRoute({ name: 'topic', topicId: route.topicId })}
            onComplete={() => {
              if (progress.completedLessonIds.includes(route.lessonId)) return
              updateProgress({
                ...progress,
                completedLessonIds: [...progress.completedLessonIds, route.lessonId],
              })
            }}
          />
        )}

        {route.name === 'quiz' && (
          <QuizScreen
            topic={topicsById.get(route.topicId)!}
            progress={progress}
            onBack={() => setRoute({ name: 'topic', topicId: route.topicId })}
            onFinish={(score, total) => {
              const best = progress.bestQuizScoreByTopic[route.topicId]
              const nextBest =
                !best || score / total > best.score / best.total
                  ? { score, total }
                  : best
              updateProgress({
                ...progress,
                bestQuizScoreByTopic: {
                  ...progress.bestQuizScoreByTopic,
                  [route.topicId]: nextBest,
                },
              })
            }}
          />
        )}
      </main>

      <footer className="footer">
        Hecho para aprender con calma, sin anuncios.
      </footer>
    </div>
  )
}
