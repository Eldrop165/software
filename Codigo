import { useMemo, useState } from 'react'
import type { Lesson, Topic } from '../content/topics'
import type { ProgressState } from '../lib/progress'

function normalize(s: string) {
  return s.trim().toLowerCase()
}

export function LessonScreen(props: {
  topic: Topic
  lessonId: string
  progress: ProgressState
  onBack: () => void
  onComplete: () => void
}) {
  const lesson = useMemo<Lesson>(() => {
    const found = props.topic.lessons.find((l) => l.id === props.lessonId)
    if (!found) throw new Error('Lesson not found')
    return found
  }, [props.lessonId, props.topic.lessons])

  const completed = props.progress.completedLessonIds.includes(lesson.id)
  const [answers, setAnswers] = useState<Record<number, string>>({})

  const practiceOkCount = useMemo(() => {
    if (!lesson.miniPractice?.length) return 0
    return lesson.miniPractice.reduce((acc, item, idx) => {
      const v = answers[idx]
      if (!v) return acc
      return normalize(v) === normalize(item.answer) ? acc + 1 : acc
    }, 0)
  }, [answers, lesson.miniPractice])

  return (
    <section className="screen">
      <div className="card">
        <div className="row">
          <button className="ghostBtn" onClick={props.onBack}>
            ← {props.topic.title}
          </button>
          <span className="pill">{completed ? 'Lección completada ✓' : 'Lección'}</span>
        </div>

        <h1 className="h1">{lesson.title}</h1>

        <div className="reading">
          {lesson.reading.map((part, idx) => (
            <div key={idx} className="readingPart">
              <h2 className="h2">{part.title}</h2>
              <p className="p">{part.body}</p>
            </div>
          ))}
        </div>

        {lesson.miniPractice?.length ? (
          <div className="practice">
            <h2 className="h2">Mini práctica</h2>
            <p className="p">
              Intenta responder. No pasa nada si te equivocas: ¡aprendemos!
            </p>

            <div className="practiceList">
              {lesson.miniPractice.map((q, idx) => {
                const v = answers[idx] ?? ''
                const ok = v ? normalize(v) === normalize(q.answer) : null
                return (
                  <div key={idx} className="practiceItem">
                    <div className="practicePrompt">{q.prompt}</div>
                    <div className="practiceRow">
                      <input
                        className="input"
                        value={v}
                        placeholder="Escribe aquí…"
                        onChange={(e) =>
                          setAnswers((prev) => ({ ...prev, [idx]: e.target.value }))
                        }
                      />
                      <span className={ok === true ? 'pillOk' : ok === false ? 'pillBad' : 'pill'}>
                        {ok === true ? 'Bien' : ok === false ? 'Intenta de nuevo' : '—'}
                      </span>
                    </div>
                  </div>
                )
              })}
            </div>

            <div className="row" style={{ marginTop: 12 }}>
              <span className="pill">
                Aciertos: {practiceOkCount}/{lesson.miniPractice.length}
              </span>
              <button className="primaryBtn" onClick={props.onComplete}>
                Marcar como completada
              </button>
            </div>
          </div>
        ) : (
          <div className="row" style={{ marginTop: 12 }}>
            <span className="pill">Sin práctica en esta lección</span>
            <button className="primaryBtn" onClick={props.onComplete}>
              Marcar como completada
            </button>
          </div>
        )}
      </div>
    </section>
  )
}




